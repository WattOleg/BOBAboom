# Локально / без CORS: прямой URL веб-приложения Apps Script
# VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Vercel: обход CORS — api/gas.js + APPS_SCRIPT_URL на сервере.
# Обязательно: APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_ID/exec
# В новых билдах при полном URL Google в VITE_* на проде автоматически используется /api/gas.
# Явно можно задать: VITE_APPS_SCRIPT_URL=/api/gas
# Локально с прокси в dev: VITE_APPS_SCRIPT_URL=/api/gas + APPS_SCRIPT_URL=... в .env

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=techcards
# Через запятую: email, которые получат роль admin при регистрации/входе
VITE_ADMIN_EMAILS=
VITE_PIN_CODE=1234
